{
  "name": "maso",
  "version": "1.0.0",
  "description": "Ultra-low latency RTSP media player for drones, CCTV, and IP cameras",
  "main": "electron/main.js",
  "homepage": "https://maso.app",
  "author": "Maso Team",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k -p \"[{name}]\" -n \"VITE,ELECTRON\" -c \"cyan.bold,magenta.bold\" \"vite\" \"wait-on tcp:5173 && cross-env NODE_ENV=development electron .\"",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "pack": "vite build && electron-builder --win"
  },
  "build": {
    "appId": "com.maso.app",
    "productName": "Maso",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/renderer/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**/*"
    ],
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "chart.js": "^4.4.2",
    "ffmpeg-static": "^5.3.0",
    "react-chartjs-2": "^5.2.0",
    "sql.js": "^1.11.0",
    "ws": "^8.16.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^29.1.0",
    "electron-builder": "^26.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.2.0",
    "wait-on": "^7.2.0"
  }
}
